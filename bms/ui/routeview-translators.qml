    // -----------------------------------------
    // Main container
    // -----------------------------------------
    Item {
        id: translators_main_container
        width: parent.width
        height: parent.height

        GridLayout {
            anchors.fill: parent

            anchors.topMargin: Math.ceil(24 * Theme.heightScale);
            anchors.leftMargin: Math.ceil(8 * Theme.widthScale);
            anchors.rightMargin: Math.ceil(8 * Theme.widthScale);
            anchors.bottomMargin: Math.ceil(8 * Theme.heightScale);

            columns: 1
            rows: 2

            rowSpacing: Math.ceil(32 * Theme.heightScale);

            Item {
                Layout.preferredHeight: Math.ceil(32 * Theme.heightScale);
                Layout.preferredWidth: parent.width
                
                RowLayout {
                    anchors.horizontalCenter: parent.horizontalCenter

                    LetterboxButton {
						readonly property string type: "sub-nav"
                    	objectName: "ui:tab"
                    	selected: !activeTab
		                text: BlackMesaEngine.getLocalizedString("#BlackMesaUI_TranslatorsTab_Proofreaders")
		                onClicked: {
		                	activeTab = 0;
		                }
		            }

		            LetterboxButton {
						readonly property string type: "sub-nav"
                    	objectName: "ui:tab"
		            	selected: activeTab
		                text: BlackMesaEngine.getLocalizedString("#BlackMesaUI_TranslatorsTab_Translators")
		                onClicked: {
		                	activeTab = 1;
		                }
		            }
                }

            }

            GridView {
            	id: grid_view
                Layout.fillHeight: true
                Layout.preferredWidth: parent.width
				focus: true

                // Dynamic calculation of item width also need to remove 16px for Scrollbar
                cellWidth: ((grid_view.width / 5) < cellW ? cellW : grid_view.width / 5) - 16 * Theme.widthScale
                cellHeight: cellH
                clip: true

				keyNavigationEnabled: true

                ScrollBar.vertical: VerticalScrollBar {
					id: scrollBar
                	visible: true
            	}

				Component.onCompleted: {
					grid_view.forceActiveFocus();
				}

				Keys.onUpPressed: {
					scrollBar.decrease()
				}
        		Keys.onDownPressed: {
					scrollBar.increase()
				}

                model: !activeTab ? translators_proofreaders : translators_credits
                delegate: !activeTab ? proofreaderDelegate : translatorDelegate
            }
        }
    }
}