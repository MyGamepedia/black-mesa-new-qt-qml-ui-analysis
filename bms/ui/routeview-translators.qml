    property int pageWidth: Math.ceil(1600 * Theme.widthScale)
    property int headerHeight: Math.ceil(64 * Theme.heightScale)
    property int headerOffset: Math.ceil(128 * Theme.heightScale)
    property int footerOffset: Math.ceil(72 * Theme.heightScale)

    property int cellW: Math.ceil(360 * Theme.widthScale)
    property int cellH: Math.ceil(220 * Theme.heightScale)

    property int itemsToShowOnRow: Math.floor(proofreadersContainer.width / cellW)

    property int activeTab: 0;
    //-------------------------------------------------
    // Proofreader container
    //-------------------------------------------------
    Component {
        id: proofreaderDelegate
        Item {
            width: GridView.view.cellWidth
            height: GridView.view.cellHeight
			Item {
				anchors.centerIn: parent
                width: parent.width - 32 * Theme.widthScale
                height: parent.height - 32 * Theme.widthScale

		        Rectangle {
		            width: parent.width
		            height: parent.height
					radius: 4
					color: '#A6000000'
		        }

		        Image {
		            id: _avatar
		            anchors.top: parent.top
		            anchors.horizontalCenter: parent.horizontalCenter
		            anchors.topMargin: 16 * Theme.heightScale
		            width: 48 * Theme.heightScale
		            height: 48 * Theme.heightScale
		            source: "image://game/ui/images/user-avatar.png"
		            fillMode: Image.Stretch
		            asynchronous: true
		        }

		        Item {
		        	id: _name
		            anchors.top: _avatar.bottom
		            anchors.topMargin: 8 * Theme.heightScale
		            anchors.leftMargin: 16 * Theme.widthScale
		            width: parent.width
		            height: _text_label.height

		            Text {
		            	id: _text_label
						anchors.horizontalCenter: parent.horizontalCenter
	                    horizontalAlignment: Text.AlignHCenter
						width: parent.width - 32
						wrapMode: Text.Wrap
		                color: Theme.colors.highlight
		                font.pixelSize: Math.ceil(16 * Theme.widthScale)
		                text: "<b>"+modelData.crowdin_name+"</b>"
		        	}
		        }


		        Text {
		            id: _nickname
		            anchors.top: _name.bottom
		            anchors.left: parent.left
		            anchors.topMargin: 8 * Theme.heightScale
		            anchors.leftMargin: 16 * Theme.widthScale
		            width: parent.width - 32

		            wrapMode: Text.Wrap
		            color: Theme.colors.highlight
		            font.pixelSize: Math.ceil(14 * Theme.widthScale)
		            text: "<i>Full Name:</i> <b>"+modelData.full_name_nick_name+"</b>"
		        }

		        Text {
		            id: _discord_nickname
		            anchors.top: _nickname.bottom
		            anchors.left: parent.left
		            anchors.topMargin: 8 * Theme.heightScale
		            anchors.leftMargin: 16 * Theme.widthScale
		            width: parent.width - 32

		            wrapMode: Text.Wrap
		            color: Theme.colors.highlight
		            font.pixelSize: Math.ceil(14 * Theme.widthScale)
		            text: "<i>Discord:</i> <b>"+modelData.discord_name+"</b>"
		        }
		        Text {
		            id: _lang
		            anchors.top: _discord_nickname.bottom
		            anchors.left: parent.left
		            anchors.topMargin: 8 * Theme.heightScale
		            anchors.leftMargin: 16 * Theme.widthScale
		            width: parent.width - 32

		            wrapMode: Text.Wrap
		            color: Theme.colors.highlight
		            font.pixelSize: Math.ceil(14 * Theme.widthScale)
		            text: "<i>Language:</i> <b>"+modelData.language+"</b>"
		        }
		    }
		}
	}
